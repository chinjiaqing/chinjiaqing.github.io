<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <% css.forEach(function(s){ %>
        <link rel="stylesheet" href="<%- s %>">
    <% }) %>
    <% js.forEach(function(s){ %>
        <script src="<%- s %>"></script>
    <% }) %>
</head>
<body>
    <div class="container">
        <nav>
        <%- asideHtml %>
    </nav>
    <article>
        <h1><%= title %></h1>
        <p class="datetime">🕓<span> <%= create_at %></span><span>⏳<%= readTimeStr %>(<%= count %>字)</span></p>
        <%- content %>
    </article>
    </div>
</body>
</html>