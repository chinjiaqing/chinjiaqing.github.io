
.article-gallery
  position: relative

.article-gallery-photos
  position: relative
  overflow: hidden

.article-gallery-img
  display: none
  max-width: 100%
  &:first-child
    display: block
  &.loaded
    position: absolute
    display: block
  img
    display: block
    max-width: 100%
    max-height: 15rem
    height: auto
    margin: 0 auto

@media (min-width: 768px)
  .article-gallery-img
    text-align: left
    img
      display: inline-block