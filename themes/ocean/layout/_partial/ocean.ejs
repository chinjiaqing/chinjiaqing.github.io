<section class="jumbotron">
  <div class="video">
    <% if (theme.ocean.overlay) { %>
      <div class="video-frame">
        <img src="<%- theme.ocean.path %>overlay-hero.png" alt="Decorative image frame">
      </div>
    <% } %>
    <div class="video-media">
      <div class="video-overlay"></div>
    </div>
    <div class="video-inner text-center text-white">
      <h1><a href="<%- url_for() %>"><%= config.title %></a></h1>
      <p><span id="jinrishici-sentence">碧琅玕绕碧梧桐，面面轩窗面面风。</span></p>
      <div><img src="<%- theme.ocean.brand %>" class="brand" alt="<%= config.title %>"></div>
    </div>
    <div class="video-learn-more">
      <a class="anchor" href="#landingpage"><i class="fe fe-mouse"></i></a>
    </div>
  </div>
  <%- js('https://sdk.jinrishici.com/v2/browser/jinrishici.js') %>
</section>
